# ============================
# NYC Taxi Fare MLOps - Environment Variables
# ============================
# Copy this file to .env and fill in the values.

# --- MinIO (S3 compatible) ---
MINIO_ROOT_USER=mlops_admin
MINIO_ROOT_PASSWORD=mlops_secret_key
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET_NAME=mlflow-artifacts
AWS_ACCESS_KEY_ID=mlops_admin
AWS_SECRET_ACCESS_KEY=mlops_secret_key

# --- PostgreSQL (MLflow backend) ---
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow_secret
POSTGRES_DB=mlflow_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- MLflow ---
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
MLFLOW_EXPERIMENT_NAME=nyc-taxi-fare

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Prefect ---
PREFECT_API_URL=http://prefect-server:4200/api

# --- Streamlit ---
STREAMLIT_PORT=8501
